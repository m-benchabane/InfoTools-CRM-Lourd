<Window x:Class="CRM_lourd.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CRM_lourd.Views"
        Title="CRM - InfoTools"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ── Palette sidebar ── -->
        <SolidColorBrush x:Key="SidebarBg"       Color="#0F172A"/>
        <SolidColorBrush x:Key="SidebarHover"    Color="#1E293B"/>
        <SolidColorBrush x:Key="SidebarActive"   Color="#1E3A8A"/>
        <SolidColorBrush x:Key="SidebarBorder"   Color="#1E293B"/>
        <SolidColorBrush x:Key="PrimaryColor"    Color="#2563EB"/>
        <SolidColorBrush x:Key="TextOnDark"      Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextOnDarkMuted" Color="#64748B"/>

        <!-- ── Bouton menu ── -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="#CBD5E1"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="FontWeight"              Value="Medium"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Padding"                 Value="0"/>
            <Setter Property="Height"                  Value="42"/>
            <Setter Property="Margin"                  Value="0,2,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource SidebarHover}"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource SidebarActive}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ SIDEBAR ══════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBg}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.3" Direction="0"/>
            </Border.Effect>

            <Grid Margin="16,24,16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Logo + titre -->
                    <RowDefinition Height="Auto"/>
                    <!-- Séparateur -->
                    <RowDefinition Height="*"/>
                    <!-- Nav -->
                    <RowDefinition Height="Auto"/>
                    <!-- Profil -->
                </Grid.RowDefinitions>

                <!-- ── Logo / Titre app ── -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource PrimaryColor}" CornerRadius="8"
                                Width="34" Height="34" Margin="0,0,10,0">
                            <Path Data="M13,3V9H21V3M13,21H21V11H13M3,21H11V15H3M3,13H11V3H3V13Z"
                                  Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="InfoTools" Foreground="White"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="CRM Platform" Foreground="{StaticResource TextOnDarkMuted}"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- ── Séparateur ── -->
                <Border Grid.Row="1" Height="1"
                        Background="{StaticResource SidebarBorder}"
                        Margin="0,0,0,20"/>

                <!-- ── Navigation ── -->
                <StackPanel Grid.Row="2" VerticalAlignment="Top">

                    <!-- Label section -->
                    <TextBlock Text="NAVIGATION"
                               Foreground="{StaticResource TextOnDarkMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="12,0,0,10"/>

                    <Button x:Name="DashboardButton" Tag="Dashboard"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M13,3V9H21V3M13,21H21V11H13M3,21H11V15H3M3,13H11V3H3V13Z"
                                  Fill="#60A5FA" Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Tableau de bord" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Clients"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                  Fill="#34D399" Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Clients" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Appointments"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19,19H5V8H19M19,3H18V1H16V3H8V1H6V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M16.53,11.06L15.47,10L10.59,14.88L8.47,12.76L7.41,13.82L10.59,17Z"
                                  Fill="#FBBF24" Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Rendez-vous" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Products"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z"
                                  Fill="#A78BFA" Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Produits" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="Invoices"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M11,17H9V11H11V17M15,17H13V14H15V17Z"
                                  Fill="#FB923C" Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="Factures" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- ── Séparateur bas ── -->
                <!-- ── Profil utilisateur ── -->
                <Border Grid.Row="3"
                        Background="{StaticResource SidebarHover}"
                        CornerRadius="10"
                        Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="{StaticResource PrimaryColor}"
                                Margin="0,0,10,0">
                            <TextBlock x:Name="txtUserInitial" Text="A"
                                       Foreground="White" FontWeight="Bold" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="txtUserName" Text="Chargement..."
                                       Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="txtUserRole" Text="..."
                                       Foreground="{StaticResource TextOnDarkMuted}" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ══════════ CONTENU PRINCIPAL ══════════ -->
        <Grid Grid.Column="1" Background="#F1F5F9">
            <ContentControl x:Name="MainContent"/>
        </Grid>

    </Grid>
</Window>
