<Window x:Class="CRM_lourd.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CRM_lourd.Views"
        Title="CRM - InfoTools"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F8FE"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATÉRAL -->
        <Border Grid.Column="0" Background="#0E2337" CornerRadius="0,10,10,0">

            <!-- MODIFICATION ICI : On utilise une Grid au lieu d'un StackPanel pour gérer le haut et le bas -->
            <Grid Margin="20,30,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- Prend toute la place disponible (Haut) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Prend juste la place nécessaire (Bas) -->
                </Grid.RowDefinitions>

                <!-- === PARTIE HAUTE : LOGO + BOUTONS === -->
                <StackPanel Grid.Row="0" VerticalAlignment="Top">

                    <StackPanel.Resources>
                        <!-- Votre Style bouton menu (inchangé) -->
                        <Style TargetType="Button" x:Key="MenuButtonStyle">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12"/>
                            <Setter Property="Margin" Value="0,10,0,10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#1D3A56"/>
                                            </Trigger>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#E9EDF7"/>
                                                <Setter Property="Foreground" Value="#2B6FFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#E9EDF7"/>
                                                <Setter Property="Foreground" Value="#2B6FFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Logo -->
                    <Image Source="Images/logo.png" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                    <!-- Liens -->
                    <Button x:Name="DashboardButton" Content="🏠  Tableau de bord" Tag="Dashboard" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click"/>
                    <Button Content="👥  Clients" Tag="Clients" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click"/>
                    <Button Content="📅  Rendez-vous" Tag="Appointments" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click"/>
                    <Button Content="📦  Produits" Tag="Products" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click"/>
                    <Button Content="💰  Factures" Tag="Invoices" Style="{StaticResource MenuButtonStyle}" Click="MenuButton_Click"/>
                </StackPanel>

                <!-- === PARTIE BASSE : PROFIL UTILISATEUR (NOUVEAU) === -->
                <Border Grid.Row="1" Background="#1D3A56" CornerRadius="12" Padding="10">
                    <StackPanel Orientation="Horizontal">
                        <!-- Cercle avec l'initiale -->
                        <Border Width="40" Height="40" CornerRadius="20" Background="#2563EB" Margin="0,0,12,0">
                            <TextBlock x:Name="txtUserInitial" Text="A" 
                                       Foreground="White" FontWeight="Bold" FontSize="18" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Infos Texte -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="txtUserName" Text="Chargement..." Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="txtUserRole" Text="..." Foreground="#9CA3AF" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- CONTENU PRINCIPAL -->
        <Grid Grid.Column="1" Background="#F5F8FE" Margin="0">
            <ContentControl x:Name="MainContent" />
        </Grid>
    </Grid>
</Window>