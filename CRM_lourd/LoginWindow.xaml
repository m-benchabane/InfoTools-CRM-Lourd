<Window x:Class="CRM_lourd.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion" Height="500" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True" FontFamily="Segoe UI">

    <Border CornerRadius="16" Background="White"
            BorderBrush="#E2E8F0" BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Opacity="0.15" ShadowDepth="0" Color="#0F172A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Accent top bar bleu -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Background="#2563EB"/>

            <!-- Contenu -->
            <StackPanel Grid.Row="1" Margin="44,36,44,40" VerticalAlignment="Center">

                <!-- Logo + Titre -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="InfoTools CRM"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Connectez-vous à votre espace"
                               FontSize="13" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Séparateur -->
                <Border Height="1" Background="#E2E8F0" Margin="0,20,0,28"/>

                <!-- Identifiant -->
                <TextBlock Text="IDENTIFIANT"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <Border x:Name="borderUser"
                        BorderBrush="#E2E8F0" BorderThickness="1.5"
                        CornerRadius="8" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Icône utilisateur via Path -->
                        <Path Grid.Column="0"
                              Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                              Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtUser"
                                 Grid.Column="1"
                                 Padding="0,13,12,13"
                                 FontSize="13"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#0F172A"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Mot de passe -->
                <TextBlock Text="MOT DE PASSE"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <Border x:Name="borderPass"
                        BorderBrush="#E2E8F0" BorderThickness="1.5"
                        CornerRadius="8" Margin="0,0,0,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Icône cadenas via Path -->
                        <Path Grid.Column="0"
                              Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                              Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="txtPass"
                                     Grid.Column="1"
                                     Padding="0,13,12,13"
                                     FontSize="13"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#0F172A"
                                     VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Bouton Connexion -->
                <Button Content="Se connecter"
                        Click="BtnLogin_Click"
                        Height="46"
                        Cursor="Hand"
                        FontSize="14" FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="9" Background="#2563EB">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1E3A8A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Bouton Annuler -->
                <Button Content="Annuler"
                        Click="BtnExit_Click"
                        Height="36"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="#94A3B8"
                        BorderThickness="0"
                        HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="7" Background="Transparent" Padding="16,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
