<UserControl x:Class="CRM_lourd.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1200"
             FontFamily="Segoe UI">

    <UserControl.Resources>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="PrimaryColor"     Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHover"     Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryLight"     Color="#EFF6FF"/>
        <SolidColorBrush x:Key="PrimaryMid"       Color="#DBEAFE"/>
        <SolidColorBrush x:Key="DangerColor"      Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBg"         Color="#FEE2E2"/>
        <SolidColorBrush x:Key="SuccessColor"     Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessBg"        Color="#DCFCE7"/>
        <SolidColorBrush x:Key="WarnColor"        Color="#D97706"/>
        <SolidColorBrush x:Key="WarnBg"           Color="#FEF3C7"/>
        <SolidColorBrush x:Key="BackgroundColor"  Color="#F1F5F9"/>
        <SolidColorBrush x:Key="SurfaceColor"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceHover"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor"      Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderFocus"      Color="#2563EB"/>

        <!-- ── TextBox ── -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding"         Value="10,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          VerticalAlignment="Center" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderFocus}"/>
                                <Setter TargetName="border" Property="Background"  Value="{StaticResource PrimaryLight}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary Button ── -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost Button (Modifier) ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger Button (Supprimer) ── -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource DangerBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource DangerColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Input Label ── -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,0,5"/>
        </Style>

        <!-- ── Section Title ── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </UserControl.Resources>

    <!-- ROOT -->
    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="32,0">
            <Border.Effect>
                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.35" Direction="270"/>
            </Border.Effect>
            <Grid Height="64">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource PrimaryColor}" CornerRadius="6"
                            Padding="10,5" Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="CRM" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="Clients &amp; Prospects"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="{StaticResource BorderColor}"
                            Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Gérez votre répertoire commercial"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL — Fiche Client -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceColor}"
                    CornerRadius="12"
                    Margin="0,0,20,0"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#CBD5E1" BlurRadius="14" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="{StaticResource PrimaryColor}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="660">
                        <StackPanel Margin="24,20,24,24">

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="3" CornerRadius="2" Background="{StaticResource PrimaryColor}" Margin="0,0,10,0"/>
                                <TextBlock Text="Fiche Contact" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Statut -->
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Statut du dossier" Style="{StaticResource InputLabel}"/>
                                <ComboBox x:Name="cbStatus"
                                          Height="38" Padding="10,8" FontSize="13"
                                          Background="White"
                                          BorderBrush="{StaticResource BorderColor}">
                                    <ComboBoxItem Content="prospect" IsSelected="True"/>
                                    <ComboBoxItem Content="actif"/>
                                    <ComboBoxItem Content="inactif"/>
                                </ComboBox>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,4,0,14"/>

                            <!-- Nom -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Nom complet" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtCustomerName" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <!-- Entreprise -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Entreprise (Optionnel)" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtCompany" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <!-- Email + Téléphone -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Email" Style="{StaticResource InputLabel}"/>
                                    <TextBox x:Name="txtCustomerEmail" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Téléphone" Style="{StaticResource InputLabel}"/>
                                    <TextBox x:Name="txtCustomerPhone" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Adresse -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Adresse" Style="{StaticResource InputLabel}"/>
                                <TextBox x:Name="txtAddress" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>

                            <!-- Code postal + Ville -->
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.7*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Code Postal" Style="{StaticResource InputLabel}"/>
                                    <TextBox x:Name="txtZip" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Ville" Style="{StaticResource InputLabel}"/>
                                    <TextBox x:Name="txtCity" Style="{StaticResource ModernTextBox}"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>

                            <!-- Actions -->
                            <Button x:Name="btnAddCustomer"
                                    Content="+ Ajouter le contact"
                                    Click="btnAddCustomer_Click"
                                    Style="{StaticResource ActionButton}"
                                    Height="40"
                                    Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="btnUpdateCustomer"
                                        Grid.Column="0"
                                        Content="Modifier"
                                        Click="btnUpdateCustomer_Click"
                                        Style="{StaticResource GhostButton}"
                                        Height="36"/>
                                <Button x:Name="btnDeleteCustomer"
                                        Grid.Column="2"
                                        Content="Supprimer"
                                        Click="btnDeleteCustomer_Click"
                                        Style="{StaticResource DangerButton}"
                                        Height="36"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT PANEL — DataGrid -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceColor}"
                    CornerRadius="12"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#CBD5E1" BlurRadius="14" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="22,16"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Répertoire " Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="Contacts" Foreground="{StaticResource PrimaryColor}"
                                       FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="dgCustomers"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="dgCustomers_SelectionChanged"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderColor}"
                              RowHeight="46"
                              Background="Transparent"
                              BorderThickness="0"
                              ColumnHeaderHeight="40">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
                                <Setter Property="Padding"         Value="14,0"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontSize"   Value="13"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceHover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="Transparent" Padding="14,0">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="STATUT" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="5" Padding="9,3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource WarnBg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="actif">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBg}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="inactif">
                                                            <Setter Property="Background" Value="{StaticResource DangerBg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource WarnColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="actif">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="inactif">
                                                                <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="NOM"        Binding="{Binding Name}"        Width="1.5*" FontWeight="Medium"/>
                            <DataGridTextColumn Header="ENTREPRISE" Binding="{Binding CompanyName}" Width="*"/>
                            <DataGridTextColumn Header="EMAIL"      Binding="{Binding Email}"       Width="1.5*"/>
                            <DataGridTextColumn Header="VILLE"      Binding="{Binding City}"        Width="0.8*"/>
                            <DataGridTextColumn Header="TÉLÉPHONE"  Binding="{Binding Phone}"       Width="*"/>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
