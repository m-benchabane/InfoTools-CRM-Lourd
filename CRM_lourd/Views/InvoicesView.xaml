<UserControl x:Class="CRM_lourd.Views.InvoicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1200"
             FontFamily="Segoe UI">

    <UserControl.Resources>

        <!-- ── Palette ── -->
        <SolidColorBrush x:Key="PrimaryColor"    Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHover"    Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryLight"    Color="#EFF6FF"/>
        <SolidColorBrush x:Key="DangerColor"     Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBg"        Color="#FEE2E2"/>
        <SolidColorBrush x:Key="SuccessColor"    Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessBg"       Color="#DCFCE7"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="SurfaceColor"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceHover"    Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor"     Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderFocus"     Color="#2563EB"/>

        <!-- ── TextBox ── -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding"         Value="10,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                          VerticalAlignment="Center" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderFocus}"/>
                                <Setter TargetName="border" Property="Background"  Value="{StaticResource PrimaryLight}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary Button ── -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost Button ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger Button ── -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource DangerBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource DangerColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Reset Button ── -->
        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BorderColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Add Line Button (vert) ── -->
        <Style x:Key="AddLineButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SuccessBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource SuccessColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BBF7D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Input Label ── -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,0,5"/>
        </Style>

        <!-- ── Section Title ── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ── DataGrid commun ── -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="RowHeight"               Value="44"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="AutoGenerateColumns"     Value="False"/>
            <Setter Property="HeadersVisibility"       Value="Column"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="SelectionMode"           Value="Single"/>
            <Setter Property="FontSize"                Value="13"/>
        </Style>

    </UserControl.Resources>

    <!-- ROOT -->
    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Background="{StaticResource SurfaceColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="32,0">
            <Border.Effect>
                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.35" Direction="270"/>
            </Border.Effect>
            <Grid Height="64">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource PrimaryColor}" CornerRadius="6"
                            Padding="10,5" Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="CRM" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M11,17H9V11H11V17M15,17H13V14H15V17Z"
                          Fill="{StaticResource PrimaryColor}"
                          Width="18" Height="18" Stretch="Uniform"
                          Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Facturation"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="{StaticResource BorderColor}"
                            Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Gérez vos factures et commandes"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL — Formulaire facture -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceColor}"
                    CornerRadius="12"
                    Margin="0,0,20,0"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#CBD5E1" BlurRadius="14" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="{StaticResource PrimaryColor}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="680">
                        <StackPanel Margin="24,20,24,24">

                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="3" CornerRadius="2" Background="{StaticResource PrimaryColor}" Margin="0,0,10,0"/>
                                <TextBlock Text="Détails Facture" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Client -->
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Client" Style="{StaticResource InputLabel}"/>
                                <ComboBox x:Name="cbClients"
                                          DisplayMemberPath="Name"
                                          Height="38" Padding="10,8" FontSize="13"
                                          Background="White"
                                          BorderBrush="{StaticResource BorderColor}"
                                          SelectionChanged="cbClients_SelectionChanged"/>
                            </StackPanel>

                            <!-- Date -->
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Date de facturation" Style="{StaticResource InputLabel}"/>
                                <DatePicker x:Name="dpInvoiceDate"
                                            Height="38"
                                            VerticalContentAlignment="Center"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1"/>
                            </StackPanel>

                            <!-- Séparateur -->
                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,4,0,16"/>

                            <!-- Produit + Qté -->
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Ajouter un produit" Style="{StaticResource InputLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="72"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cbProducts"
                                              Grid.Column="0"
                                              DisplayMemberPath="Name"
                                              Height="38" Padding="10,8" FontSize="13"
                                              Background="White"
                                              BorderBrush="{StaticResource BorderColor}"/>
                                    <TextBox x:Name="txtQty"
                                             Grid.Column="2"
                                             Text="1"
                                             Style="{StaticResource ModernTextBox}"
                                             Height="38"
                                             TextAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <Button Content="+ Ajouter à la liste"
                                    Click="btnAddLine_Click"
                                    Style="{StaticResource AddLineButton}"
                                    Height="36"
                                    Margin="0,0,0,16"/>

                            <!-- Panier -->
                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Text="Lignes de la facture" Style="{StaticResource InputLabel}"/>
                            </StackPanel>
                            <Border BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="7"
                                    Margin="0,0,0,12">
                                <ListBox x:Name="lbBasket"
                                         Height="110"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="4">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding"     Value="8,6"/>
                                            <Setter Property="Background"  Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding ProductName}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding LineTotal, StringFormat={}{0:N2} €}"
                                                           Foreground="{StaticResource PrimaryColor}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- Total -->
                            <Border Background="{StaticResource PrimaryLight}"
                                    CornerRadius="8" Padding="14,12"
                                    Margin="0,0,0,18">
                                <Grid>
                                    <TextBlock Text="TOTAL GÉNÉRAL"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtInvoiceTotal"
                                             IsReadOnly="True"
                                             FontWeight="Bold"
                                             FontSize="20"
                                             TextAlignment="Right"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource PrimaryColor}"
                                             HorizontalAlignment="Right"
                                             Width="140"/>
                                </Grid>
                            </Border>

                            <!-- Séparateur -->
                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>

                            <!-- Actions -->
                            <Button Content="Enregistrer la facture"
                                    Click="btnAddInvoice_Click"
                                    Style="{StaticResource ActionButton}"
                                    Height="40"
                                    Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="Mettre à jour"
                                        Click="btnUpdateInvoice_Click"
                                        Style="{StaticResource GhostButton}"
                                        Height="36"/>
                                <Button Grid.Column="2"
                                        Content="Supprimer"
                                        Click="btnDeleteInvoice_Click"
                                        Style="{StaticResource DangerButton}"
                                        Height="36"/>
                            </Grid>
                            <Button Content="↺  Réinitialiser"
                                    Click="btnReset_Click"
                                    Style="{StaticResource ResetButton}"
                                    Height="32"
                                    HorizontalAlignment="Center"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT PANEL — Historique + Détail -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- Historique des factures -->
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceColor}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#CBD5E1" BlurRadius="14" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Padding="22,16"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" CornerRadius="2" Background="{StaticResource PrimaryColor}" Margin="0,0,10,0"/>
                                <TextBlock Text="Historique " Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                                <TextBlock Text="Client" Foreground="{StaticResource PrimaryColor}"
                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="dgInvoices"
                                  Grid.Row="1"
                                  Style="{StaticResource ModernDataGrid}"
                                  SelectionChanged="dgInvoices_SelectionChanged"
                                  ColumnHeaderHeight="38">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
                                    <Setter Property="Padding"         Value="14,0"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="Transparent" Padding="14,0">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <!-- N° badge -->
                                <DataGridTemplateColumn Header="N°" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="5" Padding="7,3"
                                                    Background="{StaticResource PrimaryLight}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Id}"
                                                           Foreground="{StaticResource PrimaryColor}"
                                                           FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="DATE"    Binding="{Binding InvoicedAt, StringFormat=dd/MM/yyyy}" Width="*"/>
                                <!-- Montant badge vert -->
                                <DataGridTemplateColumn Header="MONTANT" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="5" Padding="9,3"
                                                    Background="{StaticResource SuccessBg}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Total, StringFormat={}{0:N2} €}"
                                                           Foreground="{StaticResource SuccessColor}"
                                                           FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Lignes de la facture sélectionnée -->
                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceColor}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#CBD5E1" BlurRadius="14" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Padding="22,14"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="3" CornerRadius="2" Background="{StaticResource PrimaryColor}" Margin="0,0,10,0"/>
                                <TextBlock Text="Lignes " Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                                <TextBlock Text="Facture sélectionnée" Foreground="{StaticResource PrimaryColor}"
                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <DataGrid x:Name="dgInvoiceItems"
                                  Grid.Row="1"
                                  Style="{StaticResource ModernDataGrid}"
                                  IsReadOnly="True"
                                  ColumnHeaderHeight="36">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
                                    <Setter Property="Padding"         Value="14,0"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="FontSize"        Value="11"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceHover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="Transparent" Padding="14,0">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PRODUIT" Binding="{Binding ProductName}" Width="2*"/>
                                <DataGridTextColumn Header="QTÉ"     Binding="{Binding Qty}"         Width="60"/>
                                <DataGridTextColumn Header="P.U."    Binding="{Binding UnitPrice, StringFormat={}{0:N2} €}" Width="100"/>
                                <DataGridTemplateColumn Header="TOTAL" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LineTotal, StringFormat={}{0:N2} €}"
                                                       Foreground="{StaticResource PrimaryColor}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
